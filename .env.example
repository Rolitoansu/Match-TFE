# ==================================================
# Match-TFE environment example
# Copy this file to .env and replace example values
# ==================================================

# ---------- App stage ----------
NODE_ENV=production
STAGE=production
JWT_SECRET=change-me-with-a-long-random-secret

# ---------- Database used by services ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=matchtfe_user
DB_PASSWORD=change-me
DB_NAME=matchtfe_db

# ---------- Postgres container bootstrap (legacy compatibility) ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=matchtfe_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=matchtfe_db

# ---------- Internal service discovery (Docker network) ----------
AUTH_SERVICE_URL=http://authservice:5000
USER_SERVICE_URL=http://userservice:5001
PROJECT_SERVICE_URL=http://projectservice:5002
NOTIFICATION_SERVICE_URL=http://notificationservice:5004

# ---------- Public URLs used by browsers ----------
FRONTEND_URL=https://match-tfe.example.com
VITE_PUBLIC_API_URL=https://match-tfe.example.com/api

# ---------- Local host ports exposed by Docker ----------
GATEWAY_BIND_PORT=8000
WEBAPP_BIND_PORT=3000

# ---------- SMTP / notifications ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=change-me
SMTP_FROM=notifications@example.com

# ---------- Reminder jobs ----------
NOTIFICATION_TIMEZONE=Europe/Madrid
PENDING_MATCHES_CRON=0 * * * *
PENDING_MATCHES_SUBJECT=Resumen de notificaciones pendientes en Match-TFE
